# Environment variables template
# Copy to .env.local and fill with your actual values
# NEVER commit .env.local to version control

# EmailJS Configuration (Server-side via @emailjs/nodejs)
EMAILJS_SERVICE_ID=your_service_id
EMAILJS_TEMPLATE_ID=your_template_id
NEXT_PUBLIC_EMAILJS_PUBLIC_KEY=your_public_key
EMAILJS_PRIVATE_KEY=your_private_key

# Upstash Redis Configuration (Optional - rate limiting degrades gracefully without it)
# Sign up at https://upstash.com/ and create a Redis database
UPSTASH_REDIS_REST_URL=your-upstash-redis-rest-url
UPSTASH_REDIS_REST_TOKEN=your-upstash-redis-rest-token

# Google reCAPTCHA v3 (Optional - form works without it)
NEXT_PUBLIC_RECAPTCHA_SITE_KEY=your_recaptcha_site_key
RECAPTCHA_SECRET_KEY=your_recaptcha_secret_key

# Supabase Configuration (Optional)
NEXT_PUBLIC_SUPABASE_URL=your-supabase-project-url
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-supabase-anon-key

# Site Configuration
NEXT_PUBLIC_SITE_URL=https://ahmedziwar.com
NEXT_PUBLIC_GA_ID=your-ga-id
